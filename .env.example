# =====================
# Configuration du serveur
# =====================

# Port du serveur (default: 3000)
PORT=3000

# Environnement (development/production)
NODE_ENV=production

# =====================
# Base de données
# =====================

# Chemin vers la base de données SQLite
DB_PATH=./goma_security.db

# =====================
# Authentification JWT
# =====================

# Secret pour les tokens JWT (CHANGEZ CETTE VALEUR!)
JWT_SECRET=votre_secret_jwt_tres_securise_ici

# Durée de validité du token (ex: 7d, 24h, 3600s)
JWT_EXPIRES_IN=7d

# =====================
# Authentification 2FA
# =====================

# Nom du service pour l'authentification 2FA
TWO_FA_SERVICE_NAME=Goma Security

# =====================
# Web Push (Notifications)
# =====================

# Clés VAPID pour les notifications push
# Générez vos clés avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=votre_cle_publique_vapid
VAPID_PRIVATE_KEY=votre_cle_privee_vapid

# Email pour les notifications VAPID
VAPID_EMAIL=mailto:votre@email.com

# =====================
# CORS (Cross-Origin Resource Sharing)
# =====================

# Origine autorisée (* pour autoriser toutes les origines)
CORS_ORIGIN=*

# =====================
# Upload de fichiers
# =====================

# Taille maximale des fichiers uploadés (en bytes)
MAX_FILE_SIZE=5242880

# Dossier de destination pour les uploads
UPLOAD_DIR=./uploads

# =====================
# Rate Limiting
# =====================

# Nombre maximum de requêtes par fenêtre de temps
RATE_LIMIT_MAX_REQUESTS=100

# Fenêtre de temps en millisecondes (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# =====================
# Logs
# =====================

# Niveau de log (error, warn, info, debug)
LOG_LEVEL=info

# =====================
# Sécurité
# =====================

# Activer HTTPS (true/false)
ENABLE_HTTPS=false

# Chemin vers le certificat SSL (si HTTPS activé)
SSL_CERT_PATH=./certs/cert.pem

# Chemin vers la clé privée SSL (si HTTPS activé)
SSL_KEY_PATH=./certs/key.pem
